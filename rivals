local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")

local LocalPlayer = Players.LocalPlayer
local Utility = require(ReplicatedStorage.Modules.Utility)


local Enabled = false


local line = Drawing.new("Line")
line.Visible = false
line.Color = Color3.fromRGB(255, 0, 0)
line.Thickness = 2
line.Transparency = 0.5

local camera = workspace.CurrentCamera


local lastTarget = nil
local lastTargetTime = 0
local TARGET_TIMEOUT = 0.5

local function isDead(target)
    local humanoid = target:FindFirstChildOfClass("Humanoid")
    return humanoid and humanoid.Health <= 0
end

local function isSameTeam(target)
    local targetTeam = target:GetAttribute("Team")
    local myTeam = LocalPlayer.Character and LocalPlayer.Character:GetAttribute("Team")
    return targetTeam and myTeam and targetTeam == myTeam
end

local function isValidTarget(target)
    if not target then return false end
    if isDead(target) then return false end
    if isSameTeam(target) then return false end
    if target == LocalPlayer.Character then return false end
    if not target:FindFirstChildOfClass("Humanoid") then return false end
    return true
end

local function getTargets()
    local targets = {}
    local myChar = LocalPlayer.Character
    if not myChar then return targets end
    
    for _, v in ipairs(workspace:GetChildren()) do
        if v == myChar then continue end
        
        local humanoid = v:FindFirstChildOfClass("Humanoid")
        if not humanoid then continue end
        if isDead(v) then continue end
        if isSameTeam(v) then continue end
        
        table.insert(targets, v)
    end
    return targets
end

local function getPosition(target)
    local head = target:FindFirstChild("Head")
    if head then return head.Position end
    
    local root = target:FindFirstChild("HumanoidRootPart")
    if root then return root.Position end
    
    return nil
end

local function getNearestTarget()
    if not Enabled then return nil end -- <<<<<< สำคัญ
    
    local char = LocalPlayer.Character
    if not char then return nil end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    
    local now = tick()
    
    if lastTarget and isValidTarget(lastTarget) and (now - lastTargetTime) < TARGET_TIMEOUT then
        return lastTarget
    end
    
    local nearest, minDist = nil, math.huge
    for _, target in ipairs(getTargets()) do
        local pos = getPosition(target)
        if pos then
            local dist = (pos - root.Position).Magnitude
            if dist < minDist then
                nearest, minDist = target, dist
            end
        end
    end
    
    if nearest then
        lastTarget = nearest
        lastTargetTime = now
    end
    
    return nearest
end

local function updateLine()
    if not Enabled then
        line.Visible = false
        return
    end
    
    local target = lastTarget
    if not target then
        line.Visible = false
        return
    end
    
    local pos = getPosition(target)
    if not pos then
        line.Visible = false
        return
    end
    
    local screenPos, onScreen = camera:WorldToViewportPoint(pos)
    local center = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
    
    if onScreen then
        line.From = center
        line.To = Vector2.new(screenPos.X, screenPos.Y)
    else
        local dir = (Vector2.new(screenPos.X, screenPos.Y) - center).Unit
        local edge = center + dir * (camera.ViewportSize.X / 2)
        
        edge = Vector2.new(
            math.clamp(edge.X, 50, camera.ViewportSize.X - 50),
            math.clamp(edge.Y, 50, camera.ViewportSize.Y - 50)
        )
        
        line.From = center
        line.To = edge
    end
    
    line.Visible = true
end

RunService.RenderStepped:Connect(function()
    if not Enabled then return end
    getNearestTarget()
    updateLine()
end)
local oldRaycast = Utility.Raycast
Utility.Raycast = function(...)
    local args = {...}
    
    if Enabled and args[4] == 999 then
        local target = getNearestTarget()
        if target then
            local pos = getPosition(target)
            if pos then
                args[3] = pos
            end
        end
    end
    
    return oldRaycast(unpack(args))
end

function SetESP(state)
    Enabled = state
    if not state then
        line.Visible = false
        lastTarget = nil
    end
end



